# Zhipu AI (GLM-4) API Key
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# PostgreSQL Database
# Local development:
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/michelin_db
# Docker Compose (use these with docker-compose up):
# DATABASE_URL=postgresql+psycopg://michelin_user:michelin_password@postgres:5432/michelin_db

# Database Configuration (Docker Compose)
POSTGRES_DB=michelin_db
POSTGRES_USER=michelin_user
POSTGRES_PASSWORD=root
POSTGRES_PORT=5432

# API Configuration
HOST=0.0.0.0
PORT=8000
API_PORT=8000
DEBUG=false

# LLM Configuration
LLM_MODEL=glm-5.1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
API_BASE_URL=https://api.z.ai/api/paas/v4
API_TIMEOUT=120

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5

# RAG Mode (set to true to enable database/vector search)
ENABLE_RAG=false

# Rate Limiting (requests per minute)
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Session Timeout (seconds)
SESSION_TIMEOUT=3600
